{
  "expo": {
    "name": "Liftbook",
    "slug": "liftbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "Liftbook",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.liftbook"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 150,
          "dark": {
            "backgroundColor": "#FFFFFF",
            "image": "./assets/images/splash-icon.png"
          }
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-status-bar",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Liftbook to attach videos to workout sets.",
          "cameraPermission": "Allow Liftbook to record videos for workout sets.",
          "microphonePermission": "Allow Liftbook to record audio with workout videos."
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "platforms": [
      "android",
      "ios"
    ]
  }
}
